  <contact>
    <exclude body1="arm_base" body2="link2"/>
    <exclude body1="arm_base" body2="link1"/>
    <exclude body1="link1" body2="link2"/>
    <exclude body1="link2" body2="link3"/>
    <exclude body1="link3" body2="link4"/>
    <exclude body1="link4" body2="link5"/>
    <exclude body1="link5" body2="link6"/>
    <exclude body1="link6" body2="eef_connect_base_link"/>
    <exclude body1="eef_connect_base_link" body2="g2_base_link"/>
    <exclude body1="g2_base_link" body2="g2_left_link"/>
    <exclude body1="g2_base_link" body2="g2_right_link"/>
  </contact>

  <actuator>
    <general class="abduction" name="FL_hip" joint="FL_hip_joint"/>
    <general class="hip" name="FL_thigh" joint="FL_thigh_joint"/>
    <general class="knee" name="FL_calf" joint="FL_calf_joint"/>
    <general class="abduction" name="FR_hip" joint="FR_hip_joint"/>
    <general class="hip" name="FR_thigh" joint="FR_thigh_joint"/>
    <general class="knee" name="FR_calf" joint="FR_calf_joint"/>
    <general class="abduction" name="RL_hip" joint="RL_hip_joint"/>
    <general class="hip" name="RL_thigh" joint="RL_thigh_joint"/>
    <general class="knee" name="RL_calf" joint="RL_calf_joint"/>
    <general class="abduction" name="RR_hip" joint="RR_hip_joint"/>
    <general class="hip" name="RR_thigh" joint="RR_thigh_joint"/>
    <general class="knee" name="RR_calf" joint="RR_calf_joint"/>
    <!-- Airbot Play actuators -->
    <!-- kp/kv 由 ControlConfig.arm_Kp/arm_Kd 通过 position_actuator_gains 在运行时写入，XML 不重复定义 -->
    <position joint="joint1" class="joint1" forcerange="-24 24" forcelimited="true" ctrllimited="true"/>
    <position joint="joint2" class="joint2" forcerange="-24 24" forcelimited="true" ctrllimited="true"/>
    <position joint="joint3" class="joint3" forcerange="-24 24" forcelimited="true" ctrllimited="true"/>
    <position joint="joint4" class="joint4" forcerange="-8 8" forcelimited="true" ctrllimited="true"/>
    <position joint="joint5" class="joint5" forcerange="-8 8" forcelimited="true" ctrllimited="true"/>
    <position joint="joint6" class="joint6" forcerange="-8 8" forcelimited="true" ctrllimited="true"/>
  <!-- <position name='gripper' tendon='gripper_gear' ctrllimited="true" ctrlrange="0. 1." kp="3" user="1" forcelimited="true" forcerange="-1 1"/> -->
  </actuator>

  <sensor>
    <jointpos joint="FL_hip_joint" name="abduction_front_left_pos"/>
    <jointpos joint="FL_thigh_joint" name="hip_front_left_pos"/>
    <jointpos joint="FL_calf_joint" name="knee_front_left_pos"/>
    <jointpos joint="RL_hip_joint" name="abduction_hind_left_pos"/>
    <jointpos joint="RL_thigh_joint" name="hip_hind_left_pos"/>
    <jointpos joint="RL_calf_joint" name="knee_hind_left_pos"/>
    <jointpos joint="FR_hip_joint" name="abduction_front_right_pos"/>
    <jointpos joint="FR_thigh_joint" name="hip_front_right_pos"/>
    <jointpos joint="FR_calf_joint" name="knee_front_right_pos"/>
    <jointpos joint="RR_hip_joint" name="abduction_hind_right_pos"/>
    <jointpos joint="RR_thigh_joint" name="hip_hind_right_pos"/>
    <jointpos joint="RR_calf_joint" name="knee_hind_right_pos"/>
    <jointvel joint="FL_hip_joint" name="abduction_front_left_vel"/>
    <jointvel joint="FL_thigh_joint" name="hip_front_left_vel"/>
    <jointvel joint="FL_calf_joint" name="knee_front_left_vel"/>
    <jointvel joint="RL_hip_joint" name="abduction_hind_left_vel"/>
    <jointvel joint="RL_thigh_joint" name="hip_hind_left_vel"/>
    <jointvel joint="RL_calf_joint" name="knee_hind_left_vel"/>
    <jointvel joint="FR_hip_joint" name="abduction_front_right_vel"/>
    <jointvel joint="FR_thigh_joint" name="hip_front_right_vel"/>
    <jointvel joint="FR_calf_joint" name="knee_front_right_vel"/>
    <jointvel joint="RR_hip_joint" name="abduction_hind_right_vel"/>
    <jointvel joint="RR_thigh_joint" name="hip_hind_right_vel"/>
    <jointvel joint="RR_calf_joint" name="knee_hind_right_vel"/>

     <!-- gyro:imu物理传感器(陀螺仪):测量角速度[wx,wy,wz] -->
    <gyro site="imu" name="gyro"/><!-- 角速度：局部坐标系 -->
    <accelerometer site="imu" name="accelerometer"/>
    <velocimeter site="imu" name="local_linvel"/>
    <framezaxis objtype="site" objname="imu" name="upvector"/>
    <framequat objtype="site" objname="imu" name="orientation"/>
    <framepos objtype="site" objname="imu" name="global_position"/>
    <framelinvel objtype="site" objname="imu" name="global_linvel"/>
    <frameangvel objtype="site" objname="imu" name="global_angvel"/> <!-- 角速度：世界坐标系 -->

    <framelinvel objtype="site" objname="FR" name="FR_global_linvel"/>
    <framelinvel objtype="site" objname="FL" name="FL_global_linvel"/>
    <framelinvel objtype="site" objname="RR" name="RR_global_linvel"/>
    <framelinvel objtype="site" objname="RL" name="RL_global_linvel"/>

    <!-- 世界坐标系足部位置（对齐 Go2 Joystick），z≈0 站立，用于 swing_feet_z 奖励 -->
    <framepos objtype="site" objname="FR" name="FR_pos"/>
    <framepos objtype="site" objname="FL" name="FL_pos"/>
    <framepos objtype="site" objname="RR" name="RR_pos"/>
    <framepos objtype="site" objname="RL" name="RL_pos"/>

    <!-- Airbot Play sensors -->
  <jointpos name="joint1_pos" joint="joint1" />
  <jointpos name="joint2_pos" joint="joint2" />
  <jointpos name="joint3_pos" joint="joint3" />
  <jointpos name="joint4_pos" joint="joint4" />
  <jointpos name="joint5_pos" joint="joint5" />
  <jointpos name="joint6_pos" joint="joint6" />
  <!-- <tendonpos name="gripper_pos" tendon="gripper_gear" /> -->

  <jointvel name="joint1_vel" joint="joint1" />
  <jointvel name="joint2_vel" joint="joint2" />
  <jointvel name="joint3_vel" joint="joint3" />
  <jointvel name="joint4_vel" joint="joint4" />
  <jointvel name="joint5_vel" joint="joint5" />
  <jointvel name="joint6_vel" joint="joint6" />
  <!-- <tendonvel name="gripper_vel" tendon="gripper_gear" /> -->

  <jointactuatorfrc name="joint1_torque" joint="joint1" />
  <jointactuatorfrc name="joint2_torque" joint="joint2" />
  <jointactuatorfrc name="joint3_torque" joint="joint3" />
  <jointactuatorfrc name="joint4_torque" joint="joint4" />
  <jointactuatorfrc name="joint5_torque" joint="joint5" />
  <jointactuatorfrc name="joint6_torque" joint="joint6" />
  <!-- <jointactuatorfrc name="gripper_torque" joint="endright" /> -->
  <!-- 末端执行器相对于机械臂安装点（armbasepoint）坐标系，与base坐标轴同向，仅原点不同 -->
  <!-- armbasepoint is defined on the arm_base body above. -->
  <framepos name="endpoint_pos" objtype="site" objname="endpoint" reftype="site" refname="armbasepoint"/>
  <framequat name="endpoint_quat" objtype="site" objname="endpoint" reftype="site" refname="armbasepoint"/>
  <framelinvel name="endpoint_vel" objtype="site" objname="endpoint" reftype="site" refname="armbasepoint"/>
   <!-- 末端执行器相对于机械臂基座（arm_base）坐标系 -->
  <framepos name="endpoint_relative_pos" objtype="site" objname="endpoint" reftype="body" refname="arm_base_on_go2"/>
  <framequat name="endpoint_relative_quat" objtype="site" objname="endpoint" reftype="body" refname="arm_base_on_go2"/>

  <!-- <gyro name="endpoint_gyro" site="endpoint"/> -->
  <!-- <accelerometer name="endpoint_acc" site="endpoint" /> -->

  <!-- armbasepoint 在世界坐标系中的位置和姿态（用于 EE 目标世界坐标可视化） -->
  <framepos name="armbasepoint_world_pos" objtype="site" objname="armbasepoint"/>
  <framequat name="armbasepoint_world_quat" objtype="site" objname="armbasepoint"/>

  <!-- 机械臂 link 碰撞检测（touch 传感器，标量，>0 表示有外部接触） -->
  <touch name="arm_touch_base"   site="touch_site_base"/>
  <touch name="arm_touch_link1"  site="touch_site_link1"/>
  <touch name="arm_touch_link2"  site="touch_site_link2"/>
  <touch name="arm_touch_link3"  site="touch_site_link3"/>
  <touch name="arm_touch_link4"  site="touch_site_link4"/>
  <touch name="arm_touch_link5"  site="touch_site_link5"/>
  <touch name="arm_touch_link6"  site="touch_site_link6"/>
  <touch name="arm_touch_eef"    site="touch_site_eef"/>
  <touch name="arm_touch_g2base" site="touch_site_g2base"/>

  </sensor>
